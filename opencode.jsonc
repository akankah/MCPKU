{
  "$schema": "https://opencode.ai/config.json",

  // Windows MCP startup fix: wrap command dgn "cmd", "/c" biar shell resolve .exe/.cmd properly
  // + naikin timeout dari 30s -> 120s
  // lihat https://github.com/anomalyco/opencode/issues/22310
  "experimental": {
    "mcp_timeout": 120000
  },

  "disabled_providers": ["mistral", "groq", "zhipuai", "openrouter", "nvidia", "openai", "opencode-go", "ollama-cloud", "kilo"],

  // B.AI custom provider — OpenAI-compatible
  "provider": {
    "bai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "B.AI",
      "options": {
        "baseURL": "https://api.b.ai/v1",
        "apiKey": "${BAI_API_KEY}"
      },
      "models": {
        "gemini-3.5-flash": {},
        "glm-5.1": {},
        "glm-5": {},
        "kimi-k2.5": {}
      }
    },
    "free-zhipuai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Free Zhipu AI",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "${ZHIPUAI_API_KEY}"
      },
      "models": {
        "glm-4-flash": {}  // free
      }
    },
    "free-groq": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Free Groq",
      "options": {
        "baseURL": "https://api.groq.com/openai/v1",
        "apiKey": "YOUR_GROQ_API_KEY"
      },
      "models": {
        "llama-3.1-8b-instant": {},
        "llama-3.3-70b-versatile": {},
        "openai/gpt-oss-120b": {},
        "openai/gpt-oss-20b": {},
        "meta-llama/llama-4-scout-17b-16e-instruct": {},
        "qwen/qwen3-32b": {},
        "groq/compound": {},
        "groq/compound-mini": {}
      }
    },
    "free-mistral": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Free Mistral",
      "options": {
        "baseURL": "https://api.mistral.ai/v1",
        "apiKey": "${MISTRAL_API_KEY}"
      },
      "models": {
        "open-mistral-7b": {},
        "open-mixtral-8x7b": {},
        "open-mistral-nemo": {},
        "mistral-small-latest": {},
        "mistral-medium-latest": {},
        "mistral-large-latest": {},
        "codestral": {},
        "pixtral-large-latest": {}
      }
    },
    "opencode": {
      "models": {
        "gpt-5-nano": {},
        "glm-5-free": {},
        "kimi-k2.5-free": {},
        "minimax-m2.5-free": {},
        "minimax-m2.7-free": {},
        "big-pickle": {},
        "deepseek-v4-flash-free": {},
        "mimo-v2.5-free": {},
        "nemotron-3-super-free": {}
      }
    },
    "free-nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Free NVIDIA NIM",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "${NVIDIA_API_KEY}"
      },
      "models": {
        "nvidia/nemotron-3-ultra-550b-a55b": {},
        "deepseek-ai/deepseek-v4-flash": {},
        "mistralai/mistral-medium-3.5-128b": {},
        "moonshotai/kimi-k2.6": {},
        "stepfun-ai/step-3.7-flash": {},
        "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning": {},
        "nvidia/cosmos3-nano-reasoner": {},
        "nvidia/cosmos3-nano": {},
        "nvidia/nemotron-3.5-content-safety": {}
      }
    },
    "free-kilo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Free Kilo Gateway",
      "options": {
        "baseURL": "https://api.kilo.ai/api/gateway",
        "apiKey": "${KILO_API_KEY}"
      },
      "models": {
        "stepfun/step-3.7-flash:free": {},
        "poolside/laguna-m.1:free": {},
        "nvidia/nemotron-3-ultra-550b-a55b:free": {},
        "nvidia/nemotron-3-super-120b-a12b:free": {},
        "google/gemma-4-26b-a4b-it:free": {},
        "openrouter/free": {}
      }
    },
    "kimchi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kimchi",
      "options": {
        "baseURL": "https://llm.kimchi.dev/openai/v1",
        "litellmProxy": true,
        "apiKey": "${KIMCHI_API_KEY}"
      },
      "models": {
        "kimi-k2.6": {},
        "kimi-k2.5": {},
        "minimax-m2.7": {},
        "nemotron-3-super-fp4": {}
      }
    },
    "free-openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Free OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "YOUR_OPENROUTER_API_KEY"
      },
      "models": {
        "google/gemma-4-31b-it:free": {},
        "google/gemma-4-26b-a4b-it:free": {},
        "nvidia/nemotron-3-super-120b-a12b:free": {},
        "nvidia/nemotron-3-ultra-550b-a55b:free": {},
        "nvidia/nemotron-3-nano-30b-a3b:free": {},
        "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free": {},
        "nvidia/nemotron-nano-12b-v2-vl:free": {},
        "nvidia/nemotron-nano-9b-v2:free": {},
        "nvidia/nemotron-3.5-content-safety:free": {},
        "openai/gpt-oss-120b:free": {},
        "openai/gpt-oss-20b:free": {},
        "qwen/qwen3-coder:free": {},
        "qwen/qwen3-next-80b-a3b-instruct:free": {},
        "meta-llama/llama-3.3-70b-instruct:free": {},
        "meta-llama/llama-3.2-3b-instruct:free": {},
        "poolside/laguna-m.1:free": {},
        "poolside/laguna-xs.2:free": {},
        "moonshotai/kimi-k2.6:free": {},
        "z-ai/glm-4.5-air:free": {},
        "liquid/lfm-2.5-1.2b-thinking:free": {},
        "liquid/lfm-2.5-1.2b-instruct:free": {},
        "nousresearch/hermes-3-llama-3.1-405b:free": {},
        "cognitivecomputations/dolphin-mistral-24b-venice-edition:free": {},
        "google/lyria-3-pro-preview": {},
        "google/lyria-3-clip-preview": {},
        "openrouter/owl-alpha": {},
        "openrouter/free": {}
      }
    }
  },

  // MCPKU — 16 stdio MCP servers from E:\MCPKU
  // All use `python <file>.py`. Path resolved by the opencode parent process
  // (which on Windows is the same shell that launched opencode).
  //
  // Required Python deps (install once):
  //   pip install "mcp[cli]" redis psycopg2-binary numpy requests GitPython playwright
  //   playwright install chromium
  //   # mcp_cache is a local module shipped in this repo, no install needed
  //
  // 🔴 CRITICAL: All API keys use ${ENV_VAR} interpolation.
  // NEVER put literal key values here — they will be committed to git.
  // Set real values in shell env or .env file.

  // ===== LOCK with approval: E:\MCPKU edits harus minta ijin dulu =====
  // Aturan: last matching wins. Path pakai kedua varian (slash/backslash) karena beda tool normalisasi beda.
  // mcp_bash path-based: allow default, ASK kalau command menyentuh E:\MCPKU.
  // mcp_autofix_run/save_error tetap DENY (auto-execute by design).
  "permission": {
    "edit":             { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "write":            { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_filesystem_write_file":      { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_filesystem_append_file":     { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_filesystem_edit_file":       { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_filesystem_create_file":     { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_filesystem_create_directory":{ "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_filesystem_move_file":       { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_filesystem_delete_file":     { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_filesystem_copy_file":       { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_bash_run_command":           { "*": "allow", "*E:/MCPKU*": "ask", "*E:\\MCPKU*": "ask" },
    "mcp_autofix_run":                "deny",
    "mcp_autofix_save_error":         "deny",
    "mcp_git_git_commit":             { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_git_git_add":                { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_git_git_checkout":           { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_git_git_reset":              { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_git_git_stash":              { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_git_git_merge":              { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_git_git_rebase":             { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_git_git_create_branch":      { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_git_git_tag":                { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" },
    "mcp_git_git_clone":              { "*": "allow", "E:/MCPKU/**": "ask", "E:\\MCPKU\\**": "ask" }
  },

  "mcp": {
    "bash": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_bash.py"],
      "enabled": true,
      "timeout": 60000
    },
    "think": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_think.py"],
      "enabled": true,
      "timeout": 60000
    },
    "sqlite": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_sqlite.py"],
      "enabled": true,
      "timeout": 60000,
      "env": {
        "SQLITE_DB_PATH": "",
        "PYTHONIOENCODING": "utf-8"
      }
    },
    "time": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_time.py"],
      "enabled": true,
      "timeout": 60000,
      "env": {
        "LOCAL_TIMEZONE": "Asia/Jakarta"
      }
    },
    "filesystem": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_filesystem.py"],
      "enabled": true,
      "timeout": 60000,
      "env": {
        "MCP_EXTRA_ALLOWED_DIR": "E:/MCPKU",
        "MCP_FS_ALLOW_ALL": "1"
      }
    },
    "memory": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_memory.py"],
      "enabled": true,
      "timeout": 60000,
      "env": {
        "MEMORY_FILE_PATH": "E:/MCPKU/memory.jsonl"
      }
    },
    "git": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_git.py"],
      "enabled": true,
      "timeout": 60000
    },
    "web": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_web.py"],
      "enabled": true,
      "timeout": 60000,
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}",
        "STACKEX_API_KEY": "${STACKEX_API_KEY}"
      }
    },
    "github": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_github.py"],
      "enabled": true,
      "timeout": 60000,
      "env": {
        "GITHUB_API_KEY": "${GITHUB_API_KEY}"
      }
    },
    "redis": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_redis.py"],
      "enabled": true,
      "timeout": 60000,
      "env": {
        "REDIS_URL": "redis://localhost:6379/0"
      }
    },
    "postgres": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_postgres.py"],
      "enabled": true,
      "timeout": 60000,
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "REDIS_URL": "redis://localhost:6379/0"
      }
    },
    "vector": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_vector.py"],
      "enabled": true,
      "timeout": 60000,
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "REDIS_URL": "redis://localhost:6379/0"
      }
    },
    "visualizer": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_visualizer.py"],
      "enabled": true,
      "timeout": 60000
    },
    "sysmon": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_sysmon.py"],
      "enabled": true,
      "timeout": 60000
    },
    "ocr": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_ocr.py"],
      "enabled": true,
      "timeout": 60000
    },
    "git_doc": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_git_doc.py"],
      "enabled": true,
      "timeout": 60000
    },
    "api_tester": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_api_tester.py"],
      "enabled": true,
      "timeout": 60000
    },
    "perf_fixer": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_perf_fixer.py"],
      "enabled": true,
      "timeout": 60000
    },
    "refactor": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_refactor.py"],
      "enabled": true,
      "timeout": 60000
    },
    "doc_intel": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_doc_intel.py"],
      "enabled": true,
      "timeout": 60000
    },
    "media": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_media.py"],
      "enabled": true,
      "timeout": 60000
    },
    "browser": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_browser.py"],
      "enabled": true,
      "timeout": 60000
    },
    // diagnostics: Auto-parse errors from any command output.
    //              AI MUST call parse_traceback / classify_error
    //              automatically on every error without waiting for user.
    "diagnostics": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_diagnostics.py"],
      "enabled": true,
      "timeout": 60000
    },
    // autofix: Closed-loop debugging. Run command → detect error → auto-fix → retry → commit.
    "autofix": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_autofix.py"],
      "enabled": true,
      "timeout": 60000
    },
    "planner": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_planner.py"],
      "enabled": true,
      "timeout": 60000
    },
    "context7": {
      "type": "local",
      "command": ["cmd", "/c", "node", "C:/Users/r/AppData/Roaming/npm/node_modules/@upstash/context7-mcp/dist/index.js"],
      "enabled": true,
      "timeout": 120000
    },
    // research: Parallel research orchestrator. Runs 6 web sources + diagnostics + memory in parallel, returns ranked consensus.
    "research": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/mcp_research.py"],
      "enabled": true,
      "timeout": 60000
    },
    // agent: Task orchestrator. Plans + executes using MCPKU tools.
    // Plans & logs stored in %TEMP%\mcpku\ (not in project dir).
    "agent": {
      "type": "local",
      "command": ["cmd", "/c", "python", "E:/MCPKU/agentku_buat_chat.py"],
      "enabled": true,
      "timeout": 60000
    }
  }
}
